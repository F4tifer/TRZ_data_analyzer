{
  "meta": {
    "type": "Test_Definitions",
    "description": "Configuration for numeric and functional tests with pass/fail criteria.",
    "version": "3.2"
  },
  "tests": [
    {
      "category": "Power_Management",
      "tests": [
        {
          "test_name": "Discharging_USB_Current",
          "csv_key": "Discharging_BATTERY_CUR",
          "unit": "mA",
          "limits": {
            "min": 95.0,
            "max": 130.0
          },
          "display_name": "Discharging USB Current"
        },
        {
          "test_name": "Discharging_USB_Voltage",
          "csv_key": "Discharging_BATTERY_V",
          "unit": "V",
          "limits": {
            "min": 3.1,
            "max": 3.6
          },
          "display_name": "Discharging Battery Voltage"
        },
        {
          "test_name": "Battery_Level_Start",
          "csv_key": "Battery_level_check",
          "unit": "%",
          "limits": {
            "min": 0.0,
            "max": 100.0
          },
          "display_name": "Battery Level at Start"
        },
        {
          "test_name": "Charging_USB_Current",
          "csv_key": "Charging_USB_Current_Check",
          "unit": "mA",
          "limits": {
            "min": 160.0,
            "max": 220.0
          },
          "display_name": "Charging USB Current"
        },
        {
          "test_name": "Charging_USB_Vbat",
          "csv_key": "Charging_USB_vbat_Check",
          "unit": "V",
          "limits": {
            "min": 3.1,
            "max": 3.6
          },
          "display_name": "Charging USB Battery Voltage"
        },
        {
          "test_name": "VBUS_Voltage",
          "csv_key": "Voltage_VBUS",
          "unit": "V",
          "limits": {
            "min": 4.75,
            "max": 5.25
          },
          "display_name": "VBUS Voltage"
        },
        {
          "test_name": "VBUS_Current",
          "csv_key": "Voltage_VBUS_current",
          "unit": "A",
          "limits": {
            "min": 0.25,
            "max": 0.35
          },
          "display_name": "VBUS Current"
        },
        {
          "test_name": "Charging_QI_Current",
          "csv_key": "Charging_QI_Current_Check",
          "unit": "mA",
          "limits": {
            "min": 230.0,
            "max": 330.0
          },
          "display_name": "Charging QI Current"
        },
        {
          "test_name": "Charging_QI_Voltage",
          "csv_key": "Charging_QI_vout_check",
          "unit": "V",
          "limits": {
            "min": 4.75,
            "max": 5.25
          },
          "display_name": "Charging QI Voltage"
